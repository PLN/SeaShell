<?xml version="1.0" encoding="utf-8"?>
<!-- Test projects restore from a local NuGet source (CI artifact directory).
     Set SEASHELL_NUPKG_DIR to the directory containing the .nupkg files. -->
<configuration>
	<packageSources>
		<clear />
		<add key="local" value="%SEASHELL_NUPKG_DIR%" />
		<add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
	</packageSources>
</configuration>
