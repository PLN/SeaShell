<?xml version="1.0" encoding="utf-8"?>
<!-- EngineTest uses ProjectReference, not NuGet packages.
     Override the parent test/nuget.config to avoid the SEASHELL_NUPKG_DIR requirement. -->
<configuration>
	<packageSources>
		<clear />
		<add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
	</packageSources>
</configuration>
