// seaw.exe window mode test — no //sea_console, so no console allocated.
// Expected to run from Task Scheduler (the real deployment context for seaw).
// Writes diagnostics + result to a marker file.

var marker = args.Length > 0 ? args[0] : Path.Combine(Path.GetTempPath(), "seaw_window_test.txt");
var lines = new List<string>();
lines.Add($"pid={Environment.ProcessId}");
lines.Add($"sessionId={System.Diagnostics.Process.GetCurrentProcess().SessionId}");
lines.Add($"user={Environment.UserName}");
lines.Add($"IsWindowMode={Sea.IsWindowMode}");
lines.Add($"processPath={Environment.ProcessPath}");
lines.Add($"cwd={Environment.CurrentDirectory}");

// Console detection diagnostics
var consoleWidth = -1;
var consoleWidthError = "";
try { consoleWidth = Console.WindowWidth; }
catch (Exception ex) { consoleWidthError = ex.GetType().Name; }

var consoleHandle = IntPtr.Zero;
var consoleHandleError = "";
try { consoleHandle = GetConsoleWindow(); }
catch (Exception ex) { consoleHandleError = ex.GetType().Name; }

lines.Add($"ConsoleWindowWidth={consoleWidth} (error={consoleWidthError})");
lines.Add($"GetConsoleWindow=0x{consoleHandle:X} (error={consoleHandleError})");
lines.Add($"HasConsoleByWidth={consoleWidth > 0}");
lines.Add($"HasConsoleByHandle={consoleHandle != IntPtr.Zero}");

// Use GetConsoleWindow as the definitive check — it returns NULL when no console
var hasConsole = consoleHandle != IntPtr.Zero;
var pass = Sea.IsWindowMode && !hasConsole;
lines.Add(pass ? "PASS" : "FAIL");
if (!pass)
	lines.Add($"reason: IsWindowMode={Sea.IsWindowMode} HasConsole={hasConsole} (expected true/false)");

File.WriteAllLines(marker, lines);
return 0;

[System.Runtime.InteropServices.DllImport("kernel32.dll")]
static extern IntPtr GetConsoleWindow();
