<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<Description>Embeddable C# and VB.NET scripting host. Compile and run scripts with full NuGet support, transitive dependency resolution, and runtime context. No daemon required.</Description>
		<PackageTags>scripting;seashell;roslyn;host;csharp;vb;repl</PackageTags>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<NoWarn>CS1591</NoWarn>
		<PackageReadmeFile>README.md</PackageReadmeFile>
	</PropertyGroup>
	<ItemGroup>
		<None Include="..\..\README.md" Pack="true" PackagePath="/" />
	</ItemGroup>
	<ItemGroup>
		<ProjectReference Include="..\SeaShell.Engine\SeaShell.Engine.csproj" />
		<!-- PrivateAssets=all: Script.dll copies to output for Engine to find,
		     but does NOT flow as a NuGet dependency to consumers. -->
		<ProjectReference Include="..\SeaShell.Script\SeaShell.Script.csproj">
			<PrivateAssets>all</PrivateAssets>
		</ProjectReference>
	</ItemGroup>

	<!-- Bundle SeaShell runtime DLLs into the NuGet package.
	     The .targets file copies them to consumer output directories. -->
	<ItemGroup>
		<None Include="build\**" Pack="true" PackagePath="build\" />
	</ItemGroup>

	<!-- Stage runtime DLLs into build/net10.0/ before packing -->
	<Target Name="StageScriptBinaries" BeforeTargets="Pack">
		<Copy SourceFiles="$(OutputPath)SeaShell.Script.dll;$(OutputPath)SeaShell.Ipc.dll;$(OutputPath)MessagePack.dll;$(OutputPath)MessagePack.Annotations.dll"
		      DestinationFolder="build\net10.0\" SkipUnchangedFiles="true" />
	</Target>
</Project>
